# Cloudflare Pages header rules. Files in public/ are copied verbatim to the
# build output root, so this lands at dist/_headers where Pages reads it.
# All matching rules are applied cumulatively (distinct header names don't clash).

# Site-wide: stop MIME sniffing. Closes the webhint "x-content-type-options"
# finding on fonts and hardens every other response too.
/*
  X-Content-Type-Options: nosniff

# Hashed, content-addressed build assets (CSS, JS, self-hosted fonts). The hash
# in the filename changes whenever the bytes change, so the URL is safe to cache
# forever — "immutable" tells the browser to skip revalidation entirely. This
# overrides the Pages default (max-age=0, must-revalidate) that forced a
# conditional request on every visit.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# HTML keeps the Pages default (public, max-age=0, must-revalidate) on purpose:
# pages are NOT hashed, so they must revalidate to surface new deploys instantly.

# Static assets in public/ are NOT content-hashed, so they can't be "immutable"
# (the filename is stable across edits). A bounded max-age still spares the
# per-visit conditional request the Pages default forces. Refresh window is
# short enough that a swapped favicon/OG image propagates within days.
/favicon.svg
  Cache-Control: public, max-age=604800
/favicon.ico
  Cache-Control: public, max-age=604800
/favicon-*.png
  Cache-Control: public, max-age=604800
/apple-touch-icon.png
  Cache-Control: public, max-age=604800
/site.webmanifest
  Cache-Control: public, max-age=604800
/og.png
  Cache-Control: public, max-age=2592000

# Per-case-study OG cards generated at build (/og/<slug>.png). Same bounded
# 30-day policy as the shared /og.png above.
/og/*
  Cache-Control: public, max-age=2592000
