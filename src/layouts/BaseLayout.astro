---
import "@/styles/global.css";
import { Font } from "astro:assets";

import type { Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/ui";
import { getBasePath, localizePath } from "@/i18n/utils";
import { buildAlternates, buildSiteGraph, ogLocale } from "@/lib/seo";
import { seo, site } from "@/data/site";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  locale: Locale;
  /** Page title without the site suffix; omit for the global home title. */
  title?: string;
  description?: string;
  /** Enable the first-visit hero "boot-up" entrance (home page only). */
  boot?: boolean;
  /** Per-page schema.org nodes, merged into the sitewide @graph in <head>. */
  jsonLd?: Record<string, unknown>[];
  /** Trail for the BreadcrumbList node; the last crumb usually omits `path`. */
  breadcrumbs?: { name: string; path?: string }[];
  /** og:type — "article" on case studies, "website" everywhere else. */
  ogType?: "website" | "article";
  /** article:* Open Graph meta, emitted only when ogType === "article". */
  article?: { publishedTime?: string; modifiedTime?: string; author?: string; section?: string; tags?: string[] };
  /** Root-relative OG/Twitter image path; defaults to the shared /og.png. */
  ogImage?: string;
  /** Alt text for the OG/Twitter image; defaults to the brand line. */
  ogImageAlt?: string;
  /** Standalone/uncrawlable routes (e.g. 404) with no localized counterpart:
   *  emit robots noindex and skip the hreflang alternates. */
  noindex?: boolean;
}

const { locale, title, description, boot, jsonLd = [], breadcrumbs, ogType = "website", article, ogImage, ogImageAlt, noindex } = Astro.props;
const t = useTranslations(locale);

const pageTitle = title ? seo[locale].titleTemplate(title) : seo[locale].title;
const pageDescription = description ?? seo[locale].description;

const siteOrigin = Astro.site ?? new URL("http://localhost:4321");
const basePath = getBasePath(Astro.url.pathname);
const alternates = buildAlternates(basePath, siteOrigin);
const canonical = alternates.find((a) => a.hreflang === locale)?.href;
// Absolute OG/Twitter image URL — a per-page card when supplied (case studies),
// otherwise the shared hand-designed /og.png. Its alt defaults to the brand line.
const ogImageUrl = new URL(ogImage ?? site.ogImage, siteOrigin).href;
const ogImageAltText = ogImageAlt ?? `${site.name} — ${site.role}`;

// Cloudflare Pages preview/branch builds inject CF_PAGES but not SITE_URL. Keep
// those per-commit deploys out of the search index so they never outrank prod.
const isPreview = !process.env.SITE_URL && !!process.env.CF_PAGES;

// Build the page's JSON-LD: the sitewide entity graph (Person/Org/WebSite),
// plus an optional BreadcrumbList, plus any per-page nodes — one <script> so
// every @id cross-reference resolves within a single graph.
const breadcrumbNode = breadcrumbs?.length
  ? {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      itemListElement: breadcrumbs.map((crumb, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: crumb.name,
        ...(crumb.path ? { item: new URL(localizePath(crumb.path, locale), siteOrigin).href } : {}),
      })),
    }
  : null;

const graph = [
  ...buildSiteGraph(siteOrigin.origin, locale),
  ...(breadcrumbNode ? [breadcrumbNode] : []),
  ...jsonLd,
];
// set:html is raw and JSON.stringify does not escape "<", so neutralise any
// literal "</script>" a future data value could contain (defensive — current
// content is author-controlled and safe).
const jsonLdHtml = JSON.stringify({ "@context": "https://schema.org", "@graph": graph }).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Mark JS as available before first paint so JS-only enhancements (e.g. the
        case-studies filter bar) can render without a no-JS flash. */}
    <script is:inline>
      try {
        document.documentElement.classList.add("js");
      } catch (e) {}
    </script>

    {/* If a language switch is pending, hide the page before first paint so it
        never flashes at the top before the body-end script restores scroll.
        Revealed by that script (or DOMContentLoaded as a failsafe). */}
    {boot && (
      <script is:inline>
        {/* First-visit only, motion-safe, and not during a language-switch
            restore: add html.boot before first paint so the hero plays its
            staged entrance. Set once per session so refresh/return skip it. */}
        try {
          if (
            !sessionStorage.getItem("booted") &&
            !sessionStorage.getItem("langScroll") &&
            !matchMedia("(prefers-reduced-motion: reduce)").matches
          ) {
            document.documentElement.classList.add("boot");
            sessionStorage.setItem("booted", "1");
          }
        } catch (e) {}
      </script>
    )}
    <script is:inline>
      try {
        if (sessionStorage.getItem("langScroll")) {
          document.documentElement.classList.add("lang-restoring");
          addEventListener("DOMContentLoaded", function () {
            document.documentElement.classList.remove("lang-restoring");
          });
        }
      } catch (e) {}
    </script>

    {/* Preload only the faces used above the fold so display:"swap" renders
        branded (not the fallback) on a normal load: the display H1 and the body
        copy. The Thai face is only above the fold on /th, so preload it there
        only — on EN it would be unused bytes. Mono is deliberately NOT preloaded:
        it dresses only small eyebrow/label text (never the LCP element) and its
        capsize fallback holds layout at CLS 0, so a preload would just compete
        with the LCP fetch for bandwidth. */}
    <Font cssVariable="--font-space-grotesk" preload />
    <Font cssVariable="--font-ibm-plex-sans" preload />
    <Font cssVariable="--font-ibm-plex-sans-thai" preload={locale === "th"} />
    <Font cssVariable="--font-ibm-plex-mono" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content={site.name} />
    {isPreview && <meta name="robots" content="noindex, nofollow" />}
    {!isPreview && noindex && <meta name="robots" content="noindex, follow" />}
    <meta name="theme-color" content="#060a12" />
    <meta name="google-site-verification" content={site.googleSiteVerification} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={canonical} />
    {!noindex && alternates.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAltText} />
    <meta property="og:locale" content={ogLocale(locale)} />
    <meta property="og:site_name" content={site.name} />
    {
      ogType === "article" && article && (
        <>
          {article.author && <meta property="article:author" content={article.author} />}
          {article.section && <meta property="article:section" content={article.section} />}
          {article.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
          {article.publishedTime && <meta property="article:published_time" content={article.publishedTime} />}
          {article.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}
        </>
      )
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAltText} />

    <script type="application/ld+json" set:html={jsonLdHtml} is:inline />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded focus:bg-accent focus:px-4 focus:py-2 focus:font-mono focus:text-sm focus:text-ink-950"
    >
      {t("skip.content")}
    </a>

    <Navbar locale={locale} />

    <main id="main">
      <slot />
    </main>

    <Footer locale={locale} />

    {/* Preserve scroll across a language switch. EN/TH pages are structurally
        identical, so we record the named [data-scroll-anchor] nearest the top of
        the content (+ its offset) before navigating, and reproduce it on the
        translated page. is:inline + non-deferred so the restore runs during parse
        (before paint) and clears the .lang-restoring guard the head set — no
        flash. Only fires when langScroll exists (set on a [data-lang-link] click),
        so normal navigation and native Back/Forward restoration are untouched.
        Plain JS (no TS) because is:inline ships verbatim. */}
    <script is:inline>
      (function () {
        var HEADER = 56; // sticky navbar height (h-14)

        // Capture on a language-switch click, before the browser navigates.
        document.addEventListener(
          "click",
          function (event) {
            var target = event.target;
            var link = target && target.closest ? target.closest("[data-lang-link]") : null;
            if (!link) return;
            var anchors = Array.prototype.slice.call(document.querySelectorAll("[data-scroll-anchor]"));
            var current = anchors[0] || null;
            var off = (current ? current.getBoundingClientRect().top : HEADER) - HEADER;
            for (var i = 0; i < anchors.length; i++) {
              var top = anchors[i].getBoundingClientRect().top - HEADER;
              if (top <= 1) { current = anchors[i]; off = top; } else break;
            }
            sessionStorage.setItem(
              "langScroll",
              JSON.stringify({
                key: current ? current.dataset.scrollAnchor : null,
                off: off,
                y: window.scrollY,
                sh: document.documentElement.scrollHeight,
              }),
            );
          },
          true,
        );

        // Restore on arrival, if we just switched language.
        var raw = sessionStorage.getItem("langScroll");
        if (raw) {
          sessionStorage.removeItem("langScroll");
          var html = document.documentElement;
          var prev = html.style.scrollBehavior;
          html.style.scrollBehavior = "auto"; // override global scroll-behavior: smooth
          try {
            var s = JSON.parse(raw);
            var key = s.key && window.CSS && CSS.escape ? CSS.escape(s.key) : s.key;
            var el = s.key ? document.querySelector('[data-scroll-anchor="' + key + '"]') : null;
            var dest;
            if (el) {
              dest = el.getBoundingClientRect().top + window.scrollY - HEADER - s.off;
            } else {
              var max = html.scrollHeight - window.innerHeight;
              dest = s.sh > window.innerHeight ? (s.y / (s.sh - window.innerHeight)) * max : s.y;
            }
            window.scrollTo(0, Math.max(0, Math.round(dest)));
          } catch (e) {
            /* malformed payload — ignore, page stays at top */
          } finally {
            html.style.scrollBehavior = prev;
            html.classList.remove("lang-restoring"); // reveal now that scroll is set
          }
        }
      })();
    </script>

    {/* First-visit boot: hold each [data-boot-watch] block (diagram, terminal)
        until it scrolls into view, so mobile users — where those blocks sit below
        the fold — actually see them play instead of finishing off-screen. Only
        runs while the hero is booting; on any failure it just reveals everything
        (paused animations resume), so content can never get stuck hidden. */}
    <script is:inline>
      (function () {
        if (!document.documentElement.classList.contains("boot")) return;
        var blocks = document.querySelectorAll("[data-boot-watch]");
        function showAll() {
          for (var i = 0; i < blocks.length; i++) blocks[i].classList.add("in-view");
        }
        try {
          if (!("IntersectionObserver" in window)) {
            showAll();
            return;
          }
          var io = new IntersectionObserver(
            function (entries, obs) {
              for (var i = 0; i < entries.length; i++) {
                if (entries[i].isIntersecting) {
                  entries[i].target.classList.add("in-view");
                  obs.unobserve(entries[i].target);
                }
              }
            },
            { threshold: 0.2 },
          );
          for (var i = 0; i < blocks.length; i++) io.observe(blocks[i]);
        } catch (e) {
          showAll();
        }
      })();
    </script>

    <script>
      // Scroll reveal — progressive enhancement; content is visible without JS
      // because the .reveal class is only added here.
      const targets = document.querySelectorAll("[data-reveal]");
      if ("IntersectionObserver" in window && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12 },
        );
        for (const el of targets) {
          el.classList.add("reveal");
          observer.observe(el);
        }
      }
    </script>
  </body>
</html>
