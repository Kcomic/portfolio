---
import "@/styles/global.css";
import { Font } from "astro:assets";

import type { Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/ui";
import { getBasePath } from "@/i18n/utils";
import { buildAlternates, ogLocale } from "@/lib/seo";
import { seo, site } from "@/data/site";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  locale: Locale;
  /** Page title without the site suffix; omit for the global home title. */
  title?: string;
  description?: string;
}

const { locale, title, description } = Astro.props;
const t = useTranslations(locale);

const pageTitle = title ? seo[locale].titleTemplate(title) : seo[locale].title;
const pageDescription = description ?? seo[locale].description;

const siteOrigin = Astro.site ?? new URL("https://bawonsak.dev");
const basePath = getBasePath(Astro.url.pathname);
const alternates = buildAlternates(basePath, siteOrigin);
const canonical = alternates.find((a) => a.hreflang === locale)?.href;
const ogImage = new URL(site.ogImage, siteOrigin).href;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Preload only the above-the-fold hero (display) face. The rest load with
        font-display: swap and show the plain generic until ready — fallbacks:[]
        in astro.config.mjs means no metric-adjusted fallback face is generated,
        so preloading every weight would only compete for bandwidth. */}
    <Font cssVariable="--font-space-grotesk" preload />
    <Font cssVariable="--font-ibm-plex-sans" />
    <Font cssVariable="--font-ibm-plex-sans-thai" />
    <Font cssVariable="--font-ibm-plex-mono" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content={site.name} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={canonical} />
    {alternates.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale(locale)} />
    <meta property="og:site_name" content={site.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded focus:bg-accent focus:px-4 focus:py-2 focus:font-mono focus:text-sm focus:text-ink-950"
    >
      {t("skip.content")}
    </a>

    <Navbar locale={locale} />

    <main id="main">
      <slot />
    </main>

    <Footer locale={locale} />

    <script>
      // Scroll reveal — progressive enhancement; content is visible without JS
      // because the .reveal class is only added here.
      const targets = document.querySelectorAll("[data-reveal]");
      if ("IntersectionObserver" in window && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12 },
        );
        for (const el of targets) {
          el.classList.add("reveal");
          observer.observe(el);
        }
      }
    </script>
  </body>
</html>
