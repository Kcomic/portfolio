---
import "@/styles/global.css";
import { Font } from "astro:assets";

import type { Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/ui";
import { getBasePath } from "@/i18n/utils";
import { buildAlternates, ogLocale } from "@/lib/seo";
import { seo, site } from "@/data/site";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  locale: Locale;
  /** Page title without the site suffix; omit for the global home title. */
  title?: string;
  description?: string;
  /** Enable the first-visit hero "boot-up" entrance (home page only). */
  boot?: boolean;
}

const { locale, title, description, boot } = Astro.props;
const t = useTranslations(locale);

const pageTitle = title ? seo[locale].titleTemplate(title) : seo[locale].title;
const pageDescription = description ?? seo[locale].description;

const siteOrigin = Astro.site ?? new URL("http://localhost:4321");
const basePath = getBasePath(Astro.url.pathname);
const alternates = buildAlternates(basePath, siteOrigin);
const canonical = alternates.find((a) => a.hreflang === locale)?.href;
const ogImage = new URL(site.ogImage, siteOrigin).href;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Mark JS as available before first paint so JS-only enhancements (e.g. the
        case-studies filter bar) can render without a no-JS flash. */}
    <script is:inline>
      try {
        document.documentElement.classList.add("js");
      } catch (e) {}
    </script>

    {/* If a language switch is pending, hide the page before first paint so it
        never flashes at the top before the body-end script restores scroll.
        Revealed by that script (or DOMContentLoaded as a failsafe). */}
    {boot && (
      <script is:inline>
        {/* First-visit only, motion-safe, and not during a language-switch
            restore: add html.boot before first paint so the hero plays its
            staged entrance. Set once per session so refresh/return skip it. */}
        try {
          if (
            !sessionStorage.getItem("booted") &&
            !sessionStorage.getItem("langScroll") &&
            !matchMedia("(prefers-reduced-motion: reduce)").matches
          ) {
            document.documentElement.classList.add("boot");
            sessionStorage.setItem("booted", "1");
          }
        } catch (e) {}
      </script>
    )}
    <script is:inline>
      try {
        if (sessionStorage.getItem("langScroll")) {
          document.documentElement.classList.add("lang-restoring");
          addEventListener("DOMContentLoaded", function () {
            document.documentElement.classList.remove("lang-restoring");
          });
        }
      } catch (e) {}
    </script>

    {/* Preload every face used above the fold so display:"optional" renders
        branded (not the fallback) on a normal load: the display H1, the body
        copy, and the mono used in the eyebrow/status/terminal labels on every
        page. The Thai face is only above the fold on /th, so preload it there
        only — on EN it would be unused bytes. */}
    <Font cssVariable="--font-space-grotesk" preload />
    <Font cssVariable="--font-ibm-plex-sans" preload />
    <Font cssVariable="--font-ibm-plex-sans-thai" preload={locale === "th"} />
    <Font cssVariable="--font-ibm-plex-mono" preload />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content={site.name} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={canonical} />
    {alternates.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale(locale)} />
    <meta property="og:site_name" content={site.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded focus:bg-accent focus:px-4 focus:py-2 focus:font-mono focus:text-sm focus:text-ink-950"
    >
      {t("skip.content")}
    </a>

    <Navbar locale={locale} />

    <main id="main">
      <slot />
    </main>

    <Footer locale={locale} />

    {/* Preserve scroll across a language switch. EN/TH pages are structurally
        identical, so we record the named [data-scroll-anchor] nearest the top of
        the content (+ its offset) before navigating, and reproduce it on the
        translated page. is:inline + non-deferred so the restore runs during parse
        (before paint) and clears the .lang-restoring guard the head set — no
        flash. Only fires when langScroll exists (set on a [data-lang-link] click),
        so normal navigation and native Back/Forward restoration are untouched.
        Plain JS (no TS) because is:inline ships verbatim. */}
    <script is:inline>
      (function () {
        var HEADER = 56; // sticky navbar height (h-14)

        // Capture on a language-switch click, before the browser navigates.
        document.addEventListener(
          "click",
          function (event) {
            var target = event.target;
            var link = target && target.closest ? target.closest("[data-lang-link]") : null;
            if (!link) return;
            var anchors = Array.prototype.slice.call(document.querySelectorAll("[data-scroll-anchor]"));
            var current = anchors[0] || null;
            var off = (current ? current.getBoundingClientRect().top : HEADER) - HEADER;
            for (var i = 0; i < anchors.length; i++) {
              var top = anchors[i].getBoundingClientRect().top - HEADER;
              if (top <= 1) { current = anchors[i]; off = top; } else break;
            }
            sessionStorage.setItem(
              "langScroll",
              JSON.stringify({
                key: current ? current.dataset.scrollAnchor : null,
                off: off,
                y: window.scrollY,
                sh: document.documentElement.scrollHeight,
              }),
            );
          },
          true,
        );

        // Restore on arrival, if we just switched language.
        var raw = sessionStorage.getItem("langScroll");
        if (raw) {
          sessionStorage.removeItem("langScroll");
          var html = document.documentElement;
          var prev = html.style.scrollBehavior;
          html.style.scrollBehavior = "auto"; // override global scroll-behavior: smooth
          try {
            var s = JSON.parse(raw);
            var key = s.key && window.CSS && CSS.escape ? CSS.escape(s.key) : s.key;
            var el = s.key ? document.querySelector('[data-scroll-anchor="' + key + '"]') : null;
            var dest;
            if (el) {
              dest = el.getBoundingClientRect().top + window.scrollY - HEADER - s.off;
            } else {
              var max = html.scrollHeight - window.innerHeight;
              dest = s.sh > window.innerHeight ? (s.y / (s.sh - window.innerHeight)) * max : s.y;
            }
            window.scrollTo(0, Math.max(0, Math.round(dest)));
          } catch (e) {
            /* malformed payload — ignore, page stays at top */
          } finally {
            html.style.scrollBehavior = prev;
            html.classList.remove("lang-restoring"); // reveal now that scroll is set
          }
        }
      })();
    </script>

    {/* First-visit boot: hold each [data-boot-watch] block (diagram, terminal)
        until it scrolls into view, so mobile users — where those blocks sit below
        the fold — actually see them play instead of finishing off-screen. Only
        runs while the hero is booting; on any failure it just reveals everything
        (paused animations resume), so content can never get stuck hidden. */}
    <script is:inline>
      (function () {
        if (!document.documentElement.classList.contains("boot")) return;
        var blocks = document.querySelectorAll("[data-boot-watch]");
        function showAll() {
          for (var i = 0; i < blocks.length; i++) blocks[i].classList.add("in-view");
        }
        try {
          if (!("IntersectionObserver" in window)) {
            showAll();
            return;
          }
          var io = new IntersectionObserver(
            function (entries, obs) {
              for (var i = 0; i < entries.length; i++) {
                if (entries[i].isIntersecting) {
                  entries[i].target.classList.add("in-view");
                  obs.unobserve(entries[i].target);
                }
              }
            },
            { threshold: 0.2 },
          );
          for (var i = 0; i < blocks.length; i++) io.observe(blocks[i]);
        } catch (e) {
          showAll();
        }
      })();
    </script>

    <script>
      // Scroll reveal — progressive enhancement; content is visible without JS
      // because the .reveal class is only added here.
      const targets = document.querySelectorAll("[data-reveal]");
      if ("IntersectionObserver" in window && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12 },
        );
        for (const el of targets) {
          el.classList.add("reveal");
          observer.observe(el);
        }
      }
    </script>
  </body>
</html>
