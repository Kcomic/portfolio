---
import type { CollectionEntry } from "astro:content";
import { useTranslations } from "@/i18n/ui";
import { localizePath } from "@/i18n/utils";
import { caseStudyLocale, caseStudySlug } from "@/lib/caseStudies";
import BaseLayout from "./BaseLayout.astro";
import CaseStudyHeader from "@/components/CaseStudyHeader.astro";
import CTASection from "@/components/CTASection.astro";
import { getContent } from "@/data/content";
import { site } from "@/data/site";

interface Props {
  entry: CollectionEntry<"caseStudies">;
  next?: { slug: string; title: string } | null;
}

const { entry, next } = Astro.props;
const { title, subtitle, role, stack, order, summary, startDate, endDate, metaTitle, metaDescription } = entry.data;
// SEO title/description: trimmed overrides for the <title>/OG/meta tags, while
// the visible header, cards, and JSON-LD headline keep the real `title`/`summary`.
const seoTitle = metaTitle ?? title;
const seoDescription = metaDescription ?? summary;
const locale = caseStudyLocale(entry);
const t = useTranslations(locale);
const cta = getContent(locale).home.cta;

// Engagement dates → article dates. startDate is required; endDate is omitted
// for ongoing work (so no fabricated dateModified). ISO 8601 for both.
const datePublished = startDate.toISOString();
const dateModified = endDate?.toISOString();

// Per-study OG card rendered at build by src/pages/og/[...slug].png.ts.
const ogImagePath = `/og/${caseStudySlug(entry)}.png`;

// TechArticle node — describes THIS case study, with author/publisher/isPartOf
// pointing at the sitewide Person/WebSite @ids so the graph resolves.
const fallback = new URL("http://localhost:4321");
const origin = (Astro.site ?? fallback).origin;
const canonical = new URL(Astro.url.pathname, Astro.site ?? fallback).href;
const articleNode = {
  "@type": "TechArticle",
  "@id": `${canonical}#article`,
  url: canonical,
  headline: title,
  description: summary,
  keywords: stack,
  inLanguage: locale,
  author: { "@id": `${origin}/#person` },
  publisher: { "@id": `${origin}/#person` },
  isPartOf: { "@id": `${origin}/#website` },
  image: `${origin}${ogImagePath}`,
  datePublished,
  ...(dateModified ? { dateModified } : {}),
};
const breadcrumbs = [
  { name: t("nav.home"), path: "/" },
  { name: t("nav.caseStudies"), path: "/case-studies" },
  { name: title },
];
---

<BaseLayout
  locale={locale}
  title={seoTitle}
  description={seoDescription}
  ogType="article"
  article={{ author: site.linkedin, section: "Case Study", tags: stack, publishedTime: datePublished, modifiedTime: dateModified }}
  ogImage={ogImagePath}
  ogImageAlt={`${title} — case study by ${site.name}`}
  jsonLd={[articleNode]}
  breadcrumbs={breadcrumbs}
>
  <article>
    <CaseStudyHeader
      locale={locale}
      title={title}
      subtitle={subtitle}
      role={role}
      stack={stack}
      order={order}
    />

    <div class="mx-auto max-w-3xl px-5 py-14 sm:px-8 lg:py-16">
      <slot />

      {
        next && (
          <nav aria-label={t("case.next")} class="mt-16 border-t border-line pt-8">
            <p class="font-mono text-[10px] tracking-[0.18em] text-dim uppercase">{t("case.next")}</p>
            <a
              href={localizePath(`/case-studies/${next.slug}`, locale)}
              class="group mt-2 inline-block font-display text-xl font-medium text-fog transition-colors hover:text-accent"
            >
              {next.title}
              <span aria-hidden="true" class="ml-1 inline-block transition-transform group-hover:translate-x-1">→</span>
            </a>
          </nav>
        )
      }
    </div>
  </article>

  <CTASection title={cta.title} body={cta.body} primary={cta.primary} />
</BaseLayout>
