---
interface Props {
  index?: string;
  eyebrow: string;
  title: string;
  lead?: string;
  as?: "h1" | "h2";
}

const { index, eyebrow, title, lead, as: Tag = "h2" } = Astro.props;
---

<div class="max-w-2xl" data-reveal>
  <p class="flex items-center gap-3 font-mono text-xs tracking-[0.18em] text-dim uppercase">
    {index && <span class="text-accent">{index}</span>}
    <span>{eyebrow}</span>
    <span aria-hidden="true" class="h-px w-12 bg-line"></span>
  </p>
  <Tag class="mt-4 font-display text-3xl leading-tight font-medium tracking-tight text-fog sm:text-4xl">
    {title}
  </Tag>
  {lead && <p class="mt-4 text-base leading-relaxed text-mist sm:text-lg">{lead}</p>}
</div>
