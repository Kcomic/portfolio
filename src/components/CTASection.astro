---
import type { CTA } from "@/data/types";
import { site } from "@/data/site";

interface Props {
  title: string;
  body: string;
  primary: CTA;
}

const { title, body, primary } = Astro.props;
---

<section class="mx-auto max-w-6xl px-5 sm:px-8">
  <div data-reveal class="bg-blueprint relative overflow-hidden rounded-md border border-line bg-ink-900/60 px-6 py-12 sm:px-12 sm:py-16">
    <h2 class="max-w-xl font-display text-2xl font-medium tracking-tight text-fog sm:text-3xl">{title}</h2>
    <p class="mt-4 max-w-xl text-base leading-relaxed text-mist">{body}</p>
    <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3">
      <a
        href={primary.href}
        class="rounded bg-accent px-5 py-2.5 text-sm font-semibold text-ink-950 transition-colors hover:bg-fog"
      >
        {primary.label}
      </a>
      <a href={`mailto:${site.email}`} class="font-mono text-sm text-mist transition-colors hover:text-accent">
        {site.email}
      </a>
    </div>
  </div>
</section>
