---
/**
 * Architecture schematic for the Smart Messaging Platform case study.
 * Drawn from the case study content: three campaign input types converge into a
 * single validation/preparation pipeline, are staged in MongoDB, scheduled by
 * Agenda, processed in memory-flat batches by background workers, delivered, and
 * aggregated by the reporting layer — all deployed on Kubernetes. Same visual
 * language as the hero schematic. Locale-agnostic (English tech labels), so the
 * EN and TH case study pages share it.
 */
import ArchitectureNode from "./ArchitectureNode.astro";

const description =
  "Architecture of the messaging platform: campaign inputs (manual entry, file upload up to one million rows, and in-system contacts) converge into a single validation pipeline, are staged in MongoDB, scheduled by Agenda, and processed in memory-flat batches by background workers before delivery; delivery results are aggregated by the reporting layer and shown in the Angular dashboard. The services are deployed on Kubernetes with Docker images built by GitHub Actions.";
---

<svg viewBox="0 0 680 512" role="img" lang="en" aria-label={description} class="h-auto w-full min-w-150 select-none">
  <title>{description}</title>
  <defs>
    <marker id="m-arrow" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M 0 0 L 8 4 L 0 8 z" fill="var(--color-accent-deep)"></path>
    </marker>
    <marker id="m-arrow-dim" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M 0 0 L 8 4 L 0 8 z" fill="var(--color-ink-700)"></path>
    </marker>
  </defs>

  {/* ---- edges (under nodes) ---- */}
  {/* campaign UI -> validation (create) */}
  <path d="M 335 68 V 200" fill="none" stroke="var(--color-ink-700)" stroke-width="1" marker-end="url(#m-arrow-dim)"></path>
  {/* three inputs converge into one validation pipeline */}
  <path d="M 174 150 H 214 V 210 H 250" fill="none" stroke="var(--color-accent-deep)" stroke-width="1" class="flow-line" marker-end="url(#m-arrow)"></path>
  <path d="M 174 222 H 250" fill="none" stroke="var(--color-accent-deep)" stroke-width="1" class="flow-line" marker-end="url(#m-arrow)"></path>
  <path d="M 174 294 H 214 V 234 H 250" fill="none" stroke="var(--color-accent-deep)" stroke-width="1" class="flow-line" marker-end="url(#m-arrow)"></path>
  {/* validation -> scheduler */}
  <path d="M 420 214 H 453 V 140 H 486" fill="none" stroke="var(--color-accent-deep)" stroke-width="1" class="flow-line" marker-end="url(#m-arrow)"></path>
  {/* validation -> MongoDB (stage) */}
  <path d="M 335 244 V 360" fill="none" stroke="var(--color-accent-deep)" stroke-width="1" class="flow-line" marker-end="url(#m-arrow)"></path>
  {/* scheduler -> workers */}
  <path d="M 571 162 V 200" fill="none" stroke="var(--color-accent-deep)" stroke-width="1" class="flow-line" marker-end="url(#m-arrow)"></path>
  {/* workers -> delivery */}
  <path d="M 571 244 V 282" fill="none" stroke="var(--color-accent-deep)" stroke-width="1" class="flow-line" marker-end="url(#m-arrow)"></path>
  {/* delivery -> MongoDB (results) */}
  <path d="M 486 304 H 453 V 378 H 420" fill="none" stroke="var(--color-accent-deep)" stroke-width="1" class="flow-line" marker-end="url(#m-arrow)"></path>
  {/* MongoDB -> reporting (aggregate) */}
  <path d="M 420 382 H 486" fill="none" stroke="var(--color-accent-deep)" stroke-width="1" class="flow-line" marker-end="url(#m-arrow)"></path>
  {/* reporting -> campaign UI (dashboards, closes the loop) */}
  <path d="M 668 360 V 44 H 420" fill="none" stroke="var(--color-ink-700)" stroke-width="1" marker-end="url(#m-arrow-dim)"></path>
  {/* deployment underpins workers + database (dotted risers) */}
  <path d="M 571 326 V 440" fill="none" stroke="var(--color-ink-700)" stroke-width="1" stroke-dasharray="2 5"></path>
  <path d="M 335 404 V 440" fill="none" stroke="var(--color-ink-700)" stroke-width="1" stroke-dasharray="2 5"></path>

  {/* ---- edge labels ---- */}
  <text x="342" y="120" fill="var(--color-dim)" font-family="var(--font-mono)" font-size="8.5">create</text>
  <text x="430" y="176" fill="var(--color-dim)" font-family="var(--font-mono)" font-size="8.5">schedule</text>
  <text x="342" y="306" fill="var(--color-dim)" font-family="var(--font-mono)" font-size="8.5">stage</text>
  <text x="430" y="340" fill="var(--color-dim)" font-family="var(--font-mono)" font-size="8.5">results</text>
  <text x="430" y="376" fill="var(--color-dim)" font-family="var(--font-mono)" font-size="8.5">aggregate</text>
  <text x="556" y="38" fill="var(--color-dim)" font-family="var(--font-mono)" font-size="8.5">dashboards</text>

  {/* ---- nodes ---- */}
  <ArchitectureNode x={250} y={24} w={170} label="Campaign UI" sub="Angular · build + monitor" revealDelay={0} />
  <ArchitectureNode x={24} y={128} w={150} label="Manual input" sub="form entry" revealDelay={0.04} />
  <ArchitectureNode x={24} y={200} w={150} label="File upload" sub="≤ 1,000,000 rows" revealDelay={0.08} />
  <ArchitectureNode x={24} y={272} w={150} label="Contacts" sub="in-system groups" revealDelay={0.12} />
  <ArchitectureNode x={250} y={200} w={170} label="Validation pipeline" sub="chunk · validate · dedupe" tone="accent" revealDelay={0.16} />
  <ArchitectureNode x={486} y={118} w={170} label="Scheduler" sub="Agenda · resumable" revealDelay={0.2} />
  <ArchitectureNode x={486} y={200} w={170} label="Batch workers" sub="memory-flat · batch ×N" tone="accent" revealDelay={0.24} />
  <ArchitectureNode x={486} y={282} w={170} label="Delivery" sub="batched dispatch" revealDelay={0.28} />
  <ArchitectureNode x={250} y={360} w={170} label="MongoDB" sub="staged · results" revealDelay={0.32} />
  <ArchitectureNode x={486} y={360} w={170} label="Reporting" sub="aggregation · indexed" revealDelay={0.36} />
  <ArchitectureNode x={24} y={440} w={632} label="Deployment" sub="Docker · GitHub Actions · Kubernetes" revealDelay={0.4} />

  {/* ---- legend ---- */}
  <g font-family="var(--font-mono)" font-size="8.5" fill="var(--color-dim)">
    <line x1="26" y1="500" x2="50" y2="500" stroke="var(--color-ink-700)" stroke-width="1"></line>
    <text x="56" y="503">control</text>
    <line x1="120" y1="500" x2="144" y2="500" stroke="var(--color-accent-deep)" stroke-width="1" stroke-dasharray="3 5"></line>
    <text x="150" y="503">data flow</text>
  </g>
</svg>
