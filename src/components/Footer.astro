---
import type { Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/ui";
import { localizePath } from "@/i18n/utils";
import { site } from "@/data/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();

const links = [
  { base: "/about", label: t("nav.about") },
  { base: "/case-studies", label: t("nav.caseStudies") },
  { base: "/expertise", label: t("nav.expertise") },
  { base: "/contact", label: t("nav.contact") },
];
---

<footer class="mt-28 border-t border-line-soft">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 sm:px-8 md:grid-cols-12">
    <div class="md:col-span-6">
      <p class="font-mono text-sm text-fog">
        bawonsak<span class="text-dim">.</span>p<span aria-hidden="true" class="text-accent">_</span>
      </p>
      <p class="mt-3 max-w-sm text-sm leading-relaxed text-dim">{t("footer.tagline")}</p>
    </div>

    <nav aria-label={t("nav.footer")} class="md:col-span-3">
      <ul class="flex flex-col gap-2.5 text-sm">
        {
          links.map(({ base, label }) => (
            <li>
              <a href={localizePath(base, locale)} class="text-mist transition-colors hover:text-fog">
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="md:col-span-3">
      <ul class="flex flex-col gap-2.5 font-mono text-sm">
        <li>
          <a href={`mailto:${site.email}`} class="text-mist transition-colors hover:text-accent">
            {site.email}
          </a>
        </li>
        <li>
          <a href={site.github} rel="me noopener" class="text-mist transition-colors hover:text-fog">
            GitHub
          </a>
        </li>
        <li>
          <a href={site.linkedin} rel="me noopener" class="text-mist transition-colors hover:text-fog">
            LinkedIn
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-line-soft">
    <div
      class="mx-auto flex max-w-6xl flex-col gap-2 px-5 py-5 font-mono text-xs text-dim sm:flex-row sm:items-center sm:justify-between sm:px-8"
    >
      <p>© {year} {site.name}</p>
      <p>{t("footer.colophon")}</p>
    </div>
  </div>
</footer>
