---
/**
 * Engagement phases laid out horizontally on desktop — five columns under a
 * shared rule — and stacked on mobile. Distinct from SystemFlowDiagram's rail.
 */
import type { TimelineItem } from "@/data/types";

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;
---

<ol class="grid gap-x-6 gap-y-8 sm:grid-cols-2 lg:grid-cols-5">
  {
    items.map((item) => (
      <li data-reveal class="border-t border-line pt-4">
        <p class="font-mono text-xs text-accent">{item.step}</p>
        <h3 class="mt-2 font-display text-base font-medium text-fog">{item.title}</h3>
        <p class="mt-2 text-sm leading-relaxed text-dim">{item.body}</p>
      </li>
    ))
  }
</ol>
