---
import type { Locale } from "@/i18n/config";
import { useTranslations } from "@/i18n/ui";
import { getContent } from "@/data/content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import Timeline from "@/components/Timeline.astro";
import CTASection from "@/components/CTASection.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const about = getContent(locale).about;

// ProfilePage node — marks this page as the canonical profile of #person, so
// search engines tie the biography here to the sitewide Person entity.
const fallback = new URL("http://localhost:4321");
const origin = (Astro.site ?? fallback).origin;
const canonical = new URL(Astro.url.pathname, Astro.site ?? fallback).href;
const profileNode = {
  "@type": "ProfilePage",
  "@id": `${canonical}#webpage`,
  url: canonical,
  inLanguage: locale === "th" ? "th-TH" : "en-US",
  isPartOf: { "@id": `${origin}/#website` },
  about: { "@id": `${origin}/#person` },
  mainEntity: { "@id": `${origin}/#person` },
};
const breadcrumbs = [{ name: t("nav.home"), path: "/" }, { name: about.title }];
---

<BaseLayout
  locale={locale}
  title={about.metaTitle ?? about.title}
  description={about.metaDescription}
  jsonLd={[profileNode]}
  breadcrumbs={breadcrumbs}
>
  <section data-scroll-anchor="about-intro" class="bg-blueprint border-b border-line-soft">
    <div class="mx-auto max-w-6xl px-5 pt-16 pb-14 sm:px-8 lg:pt-24 lg:pb-20">
      <div class="grid gap-12 lg:grid-cols-12">
        <div class="lg:col-span-7">
          <p class="font-mono text-xs tracking-[0.18em] text-dim uppercase">01 · {about.title}</p>
          <h1 class="mt-4 font-display text-3xl leading-tight font-medium tracking-tight text-fog sm:text-4xl lg:text-5xl">
            {about.heading}
          </h1>
          <div class="mt-7 flex max-w-2xl flex-col gap-5 text-base leading-relaxed text-mist sm:text-lg">
            {about.paragraphs.map((p) => <p>{p}</p>)}
          </div>
        </div>

        <aside class="lg:col-span-5 lg:border-l lg:border-line-soft lg:pl-10" data-reveal>
          <h2 class="font-mono text-[10px] tracking-[0.18em] text-dim uppercase">{about.fits.title}</h2>
          <ul class="mt-4 flex flex-col gap-2.5">
            {
              about.fits.items.map((item) => (
                <li class="flex items-center gap-3 text-sm text-mist">
                  <span aria-hidden="true" class="h-px w-4 bg-accent-deep" />
                  {item}
                </li>
              ))
            }
          </ul>

          <h2 class="mt-10 font-mono text-[10px] tracking-[0.18em] text-dim uppercase">{about.focus.title}</h2>
          <dl class="mt-4 flex flex-col gap-3">
            {
              about.focus.items.map(({ term, gloss }) => (
                <div class="text-sm leading-relaxed">
                  <dt class="inline font-medium text-fog">{term}</dt>
                  <dd class="inline text-dim"> — {gloss}</dd>
                </div>
              ))
            }
          </dl>
        </aside>
      </div>

      <div data-reveal class="mt-14 max-w-2xl border-t border-line pt-6">
        <h2 class="font-mono text-[10px] tracking-[0.18em] text-dim uppercase">{about.direction.title}</h2>
        <p class="mt-3 text-base leading-relaxed text-mist">{about.direction.body}</p>
      </div>
    </div>
  </section>

  <section data-scroll-anchor="engagement" class="mx-auto max-w-6xl px-5 py-20 sm:px-8 lg:py-24">
    <SectionHeading
      index={about.engagement.index}
      eyebrow={about.engagement.eyebrow}
      title={about.engagement.title}
      lead={about.engagement.lead}
    />
    <div class="mt-12">
      <Timeline items={about.engagement.items} />
    </div>
  </section>

  <CTASection title={about.cta.title} body={about.cta.body} primary={about.cta.primary} />
</BaseLayout>
