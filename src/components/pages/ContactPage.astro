---
import type { Locale } from "@/i18n/config";
import { getContent } from "@/data/content";
import { site } from "@/data/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/ContactForm.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const contact = getContent(locale).contact;
---

<BaseLayout locale={locale} title={contact.title} description={contact.lead}>
  <section data-scroll-anchor="contact-intro" class="bg-blueprint border-b border-line-soft">
    <div class="mx-auto max-w-6xl px-5 pt-16 pb-12 sm:px-8 lg:pt-24 lg:pb-16">
      <p class="font-mono text-xs tracking-[0.18em] text-dim uppercase">{contact.title}</p>
      <h1 class="mt-4 max-w-3xl font-display text-3xl leading-tight font-medium tracking-tight text-fog sm:text-4xl lg:text-5xl">
        {contact.heading}
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-relaxed text-mist sm:text-lg">{contact.lead}</p>
    </div>
  </section>

  <section data-scroll-anchor="contact-form" class="mx-auto max-w-6xl px-5 py-14 sm:px-8 lg:py-16">
    <div class="grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-4" data-reveal>
        <h2 class="font-mono text-[10px] tracking-[0.18em] text-dim uppercase">{contact.emailLabel}</h2>
        <a
          href={`mailto:${site.email}`}
          class="mt-3 inline-block font-mono text-base break-all text-accent underline decoration-accent-deep underline-offset-4 transition-colors hover:text-fog"
        >
          {site.email}
        </a>

        <h2 class="mt-10 font-mono text-[10px] tracking-[0.18em] text-dim uppercase">{contact.socialsLabel}</h2>
        <ul class="mt-3 flex flex-col gap-2 font-mono text-sm">
          <li>
            <a href={site.github} rel="me noopener" class="text-mist transition-colors hover:text-fog">GitHub ↗</a>
          </li>
          <li>
            <a href={site.linkedin} rel="me noopener" class="text-mist transition-colors hover:text-fog">LinkedIn ↗</a>
          </li>
        </ul>
      </div>

      <div class="lg:col-span-8" data-reveal>
        <h2 class="font-display text-lg font-medium text-fog">{contact.form.heading}</h2>
        <div class="mt-6">
          <ContactForm form={contact.form} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
