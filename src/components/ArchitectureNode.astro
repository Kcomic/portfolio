---
/**
 * One node in an SVG schematic. Renders inside an <svg> element.
 * Coordinates are in the parent viewBox space.
 */
interface Props {
  x: number;
  y: number;
  w?: number;
  h?: number;
  label: string;
  sub?: string;
  tone?: "default" | "accent";
}

const { x, y, w = 130, h = 44, label, sub, tone = "default" } = Astro.props;

const stroke = tone === "accent" ? "var(--color-accent-deep)" : "var(--color-line)";
const labelY = sub ? y + 19 : y + h / 2 + 3.5;
---

<g>
  <rect
    x={x}
    y={y}
    width={w}
    height={h}
    rx="4"
    fill="var(--color-ink-900)"
    stroke={stroke}
    stroke-width="1"
  ></rect>
  {/* corner tick, echoing PanelCard */}
  <path
    d={`M ${x} ${y + 8} V ${y + 4} Q ${x} ${y} ${x + 4} ${y} H ${x + 8}`}
    fill="none"
    stroke={tone === "accent" ? "var(--color-accent)" : "var(--color-ink-700)"}
    stroke-width="1.5"
  ></path>
  <text
    x={x + 12}
    y={labelY}
    fill="var(--color-fog)"
    font-family="var(--font-mono)"
    font-size="10.5"
    letter-spacing="0.08em"
  >
    {label.toUpperCase()}
  </text>
  {
    sub && (
      <text
        x={x + 12}
        y={y + 33}
        fill="var(--color-dim)"
        font-family="var(--font-mono)"
        font-size="8.5"
      >
        {sub}
      </text>
    )
  }
</g>
