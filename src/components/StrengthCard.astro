---
import type { Strength } from "@/data/types";
import GlowCard from "./GlowCard.astro";

interface Props {
  strength: Strength;
  index: number;
  class?: string;
}

const { strength, index, class: className } = Astro.props;
const n = String(index + 1).padStart(2, "0");
---

<div data-reveal class={className}>
  <GlowCard class="h-full">
    <p class="font-mono text-xs text-dim">{n}</p>
    <h3 class="mt-3 font-display text-lg font-medium text-fog">{strength.title}</h3>
    <p class="mt-2.5 text-sm leading-relaxed text-mist">{strength.body}</p>
  </GlowCard>
</div>
